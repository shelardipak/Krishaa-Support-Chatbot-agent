OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=350
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Set this only when the stored collection vectors use a custom dimension.
OPENAI_EMBEDDING_DIMENSIONS=
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=
QDRANT_VECTOR_NAME=
QDRANT_SCORE_THRESHOLD=0.35
QDRANT_ALLOW_FALLBACK=false
RAG_MAX_CONTEXT_CHARS=12000
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=krishaa-support-chatbot
SUPABASE_URL=
SUPABASE_STORAGE_BUCKET=
# Public bucket containing source PDFs. Preserve each Qdrant source_path when uploading.
SUPABASE_DOCUMENT_BUCKET=
GRADIO_SHARE=false
GRADIO_SERVER_PORT=7860

# Lead notification email. For Gmail, use smtp.gmail.com and an App Password.
LEAD_NOTIFICATION_EMAIL=
SMTP_HOST=
SMTP_PORT=587
# Your full Gmail address is still required as the SMTP login identity.
SMTP_USERNAME=
# Use the 16-character Google App Password, never your Google account password.
SMTP_APP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
